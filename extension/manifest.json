{
    "manifest_version": 3,
    "name": "LeetCode Notes",
    "version": "1.0",
    "permissions": ["activeTab", "scripting", "storage", "tabs"],
    "background": {
        "service_worker": "background.js"
    },
    "host_permissions": ["https://leetcode.com/*"],
    "action": {
      "default_popup": "popup.html"
    },
    "content_scripts": [
      {
        "matches": ["https://leetcode.com/problems/*"],
        "js": ["content.js"]
      }
    ]
  }